# ── Database (Neon PostgreSQL) ──
DATABASE_URL="postgresql://user:password@ep-xxxx.us-east-2.aws.neon.tech/flintbeam?sslmode=require"

# ── NextAuth ──
AUTH_SECRET="generate-with-openssl-rand-base64-32"
# AUTH_GOOGLE_ID="your-google-client-id.apps.googleusercontent.com"
# AUTH_GOOGLE_SECRET="GOCSPX-xxxxxxxxxxxx"

# ── PayPal ──
NEXT_PUBLIC_PAYPAL_CLIENT_ID="your-paypal-client-id"
PAYPAL_SECRET="your-paypal-secret"
PAYPAL_BASE="https://api-m.sandbox.paypal.com"

# ── Resend (Transactional Email) ──
RESEND_API_KEY="re_xxxxxxxxxxxx"

# ── Upstash Redis (Rate Limiting) ──
# Optional - falls back to in-memory rate limiter
# UPSTASH_REDIS_REST_URL="https://xxx.upstash.io"
# UPSTASH_REDIS_REST_TOKEN="xxxxxxxxxxxx"

# ── Google Analytics ──
NEXT_PUBLIC_GA_ID="G-XXXXXXXXXX"

# ── App ──
NEXT_PUBLIC_APP_URL="http://localhost:3000"
